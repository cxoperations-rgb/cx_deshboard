{
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/api/data",   "dest": "/api/data.js" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
